# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Create the database first:
#   createdb sr_billing       (or via psql:  CREATE DATABASE sr_billing;)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sr_billing?schema=public"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
# Frontend origin allowed by CORS (Vite dev server default is 5173)
CLIENT_ORIGIN="http://localhost:5173"

# ─── Seed passwords (used by `npm run seed`) ───────────────────────────────────
# The owner/admin and every billing counter get these passwords on seed.
SEED_ADMIN_PASSWORD="admin123"
SEED_COUNTER_PASSWORD="counter123"
